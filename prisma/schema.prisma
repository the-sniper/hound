generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String          @id @default(cuid())
  email     String          @unique
  name      String?
  password  String
  projects  ProjectMember[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Project {
  id          String          @id @default(cuid())
  name        String
  baseUrl     String
  description String?
  members     ProjectMember[]
  tests       Test[]
  runs        TestRun[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectMember {
  id        String  @id @default(cuid())
  role      Role    @default(MEMBER)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@unique([userId, projectId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Test {
  id          String     @id @default(cuid())
  name        String
  description String?
  status      TestStatus @default(DRAFT)
  tags        String     @default("")
  steps       TestStep[]
  runs        TestRun[]
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum TestStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

model TestStep {
  id          String       @id @default(cuid())
  orderIndex  Int
  type        StepType
  description String
  config      String       @default("{}")
  test        Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId      String
  results     StepResult[]
  caches      StepCache[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum StepType {
  NAVIGATE
  CLICK
  TYPE
  WAIT
  WAIT_FOR_URL
  ASSERT_TEXT
  ASSERT_ELEMENT
  ASSERT_VISUAL
  AI_CHECK
  AI_EXTRACT
  AI_ACTION
  JAVASCRIPT
  SCREENSHOT
  HOVER
  SELECT
  PRESS_KEY
  SCROLL
}

model TestRun {
  id              String       @id @default(cuid())
  status          RunStatus    @default(PENDING)
  environment     String       @default("production")
  baseUrl         String
  duration        Int?
  results         StepResult[]
  failureAnalysis String?
  test            Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId          String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
}

enum RunStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  ERROR
  CANCELLED
}

model StepResult {
  id            String           @id @default(cuid())
  status        StepResultStatus @default(PENDING)
  duration      Int?
  screenshotUrl String?
  error         String?
  logs          String?
  aiResponse    String?
  step          TestStep         @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId        String
  run           TestRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId         String
  createdAt     DateTime         @default(now())
}

enum StepResultStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
}

model StepCache {
  id         String   @id @default(cuid())
  selector   String
  attributes String   @default("{}")
  screenshot String?
  step       TestStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

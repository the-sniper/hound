generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  password     String
  anthropicKey String?
  openaiKey    String?
  projects     ProjectMember[]
  runs         TestRun[]
  comments     Comment[]
  activityLogs ActivityLog[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Project {
  id                 String              @id @default(cuid())
  name               String
  baseUrl            String
  description        String?
  perfBudgetLcp      Int?
  perfBudgetCls      Float?
  perfBudgetInp      Int?
  perfBudgetTtfb     Int?
  wcagLevel          String              @default("AA")
  members            ProjectMember[]
  tests              Test[]
  runs               TestRun[]
  environments       Environment[]
  stepCaches         StepCache[]
  authStates         AuthState[]
  securityFindings   SecurityFinding[]
  schedules          Schedule[]
  webhooks           Webhook[]
  comments           Comment[]
  activityLogs       ActivityLog[]
  plugins            ProjectPlugin[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Environment {
  id          String    @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean   @default(false)
  variables   Json      @default("{}")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  runs        TestRun[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([projectId, name])
}

model ProjectMember {
  id        String  @id @default(cuid())
  role      Role    @default(MEMBER)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@unique([userId, projectId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Test {
  id                String     @id @default(cuid())
  name              String
  description       String?
  status            TestStatus @default(DRAFT)
  tags              String     @default("")
  continueOnFailure Boolean    @default(false)
  steps             TestStep[]
  runs              TestRun[]
  project           Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId         String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

enum TestStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

model TestStep {
  id          String       @id @default(cuid())
  orderIndex  Int
  type        StepType
  description String
  config      Json         @default("{}")
  maxRetries  Int          @default(0)
  test        Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId      String
  results     StepResult[]
  caches      StepCache[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum StepType {
  NAVIGATE
  CLICK
  TYPE
  WAIT
  WAIT_FOR_URL
  ASSERT_TEXT
  ASSERT_ELEMENT
  ASSERT_VISUAL
  AI_CHECK
  AI_EXTRACT
  AI_ACTION
  JAVASCRIPT
  SCREENSHOT
  HOVER
  SELECT
  PRESS_KEY
  SCROLL
  SAVE_AUTH
  LOAD_AUTH
  MOCK_ROUTE
  REMOVE_MOCK
  CONDITIONAL
  SKIP_IF
  ASSERT_ACCESSIBLE
  SECURITY_SCAN
}

model TestRun {
  id                   String                @id @default(cuid())
  status               RunStatus             @default(PENDING)
  baseUrl              String
  duration             Int?
  recordVideo          Boolean               @default(false)
  videoUrl             String?
  harUrl               String?
  accessibilityScore   Int?
  securityGrade        String?
  results              StepResult[]
  failureAnalysis      Json?
  accessibilityResults AccessibilityResult[]
  performanceMetrics   PerformanceMetric[]
  securityFindings     SecurityFinding[]
  test                 Test                  @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId               String
  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            String
  environment          Environment?          @relation(fields: [environmentId], references: [id])
  environmentId        String?
  user                 User?                 @relation(fields: [userId], references: [id])
  userId               String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime              @default(now())
}

enum RunStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  ERROR
  CANCELLED
}

model StepResult {
  id                   String                @id @default(cuid())
  status               StepResultStatus      @default(PENDING)
  duration             Int?
  screenshotUrl        String?
  error                String?
  logs                 String?
  aiResponse           String?
  cacheHit             Boolean               @default(false)
  retryCount           Int                   @default(0)
  accessibilityResults AccessibilityResult[]
  performanceMetrics   PerformanceMetric[]
  step                 TestStep              @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId               String
  run                  TestRun               @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId                String
  createdAt            DateTime              @default(now())
}

enum StepResultStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  SKIPPED
}

model StepCache {
  id         String   @id @default(cuid())
  cacheKey   String
  selector   String
  branch     String?
  attributes Json     @default("{}")
  screenshot String?
  step       TestStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId     String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId, cacheKey, branch])
}

model AuthState {
  id        String   @id @default(cuid())
  name      String
  stateData Json
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

model AccessibilityResult {
  id            String   @id @default(cuid())
  ruleId        String
  impact        String
  wcagCriteria  String
  description   String
  target        String
  html          String?
  remediation   String?
  stepResult    StepResult @relation(fields: [stepResultId], references: [id], onDelete: Cascade)
  stepResultId  String
  run           TestRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId         String
  createdAt     DateTime   @default(now())

  @@index([runId])
}

model PerformanceMetric {
  id            String     @id @default(cuid())
  name          String
  value         Float
  unit          String     @default("ms")
  budgetMax     Float?
  overBudget    Boolean    @default(false)
  stepResult    StepResult @relation(fields: [stepResultId], references: [id], onDelete: Cascade)
  stepResultId  String
  run           TestRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId         String
  createdAt     DateTime   @default(now())

  @@index([runId, name])
}

model SecurityFinding {
  id            String   @id @default(cuid())
  type          String
  severity      String
  title         String
  description   String
  evidence      String?
  remediation   String?
  location      String?
  run           TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId         String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  createdAt     DateTime @default(now())

  @@index([runId])
  @@index([projectId, type])
}

model Schedule {
  id            String         @id @default(cuid())
  name          String
  cronExpression String
  enabled       Boolean        @default(true)
  timezone      String         @default("UTC")
  testIds       Json           @default("[]")
  environmentId String?
  region        String?
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@index([enabled, nextRunAt])
}

model Webhook {
  id         String   @id @default(cuid())
  name       String
  url        String
  events     Json     @default("[\"run_failed\"]")
  headers    Json     @default("{}")
  enabled    Boolean  @default(true)
  secret     String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  targetType String
  targetId   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([projectId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}

model PluginDefinition {
  id          String          @id @default(cuid())
  name        String          @unique
  version     String
  description String?
  author      String?
  category    String
  entrypoint  String
  configSchema Json           @default("{}")
  installs    ProjectPlugin[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectPlugin {
  id         String           @id @default(cuid())
  enabled    Boolean          @default(true)
  config     Json             @default("{}")
  plugin     PluginDefinition @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  pluginId   String
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([pluginId, projectId])
}

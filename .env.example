# Database — PostgreSQL (production) or SQLite (local dev)
# PostgreSQL: postgresql://hound:hound@localhost:5432/hound
# SQLite:     file:./prisma/dev.db (also change provider in prisma/schema.prisma)
DATABASE_URL="postgresql://hound:hound@localhost:5432/hound"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# AI API Keys
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Artifact Storage — "local" (default) or "s3"
STORAGE_PROVIDER="local"

# S3-compatible storage (when STORAGE_PROVIDER=s3)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="hound-artifacts"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_REGION="us-east-1"

# Artifact retention (days) — artifacts older than this are auto-cleaned
ARTIFACT_RETENTION_DAYS="90"
